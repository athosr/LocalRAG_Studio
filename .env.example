# Must match docker-compose.yml (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB).
# Host port is 5433 in compose so migrations do not hit another Postgres on 5432.
# If you ever change those env vars, run: docker compose down -v  (wipes data) then up again.
DATABASE_URL=postgresql://rag:rag@127.0.0.1:5433/ragstudio

# Optional: Python executable for the rag-service subprocess (Electron main).
# LOCALRAG_PYTHON=C:\Path\To\python.exe

# Optional: HTTP port for rag-service (default 8787).
# LOCALRAG_RAG_PORT=8787
